{
  "name": "@acme/admin",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "description": "WordPress Commerce OS Admin — internal Platform Admin dashboard (Expo + React Native + React Native Web). Internal-only; deploys separately from the merchant app.",
  "scripts": {
    "start": "expo start",
    "web": "expo start --web",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "export:web": "expo export --platform web",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "jest",
    "test:ci": "jest --ci --runInBand --forceExit"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@tanstack/react-query": "^5.101.0",
    "expo": "^56.0.12",
    "expo-constants": "~56.0.18",
    "expo-linking": "~56.0.14",
    "expo-router": "~56.2.11",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.14",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^56.0.4",
    "eslint-config-prettier": "^10.1.8",
    "jest": "~29.7.0",
    "jest-expo": "~56.0.5",
    "prettier": "^3.8.4",
    "react-test-renderer": "^19.2.3",
    "typescript": "~6.0.3"
  }
}
