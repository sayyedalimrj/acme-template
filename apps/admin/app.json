{
  "expo": {
    "name": "WordPress Commerce OS Admin",
    "slug": "ww-admin-dashboard",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "wwadmin",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "platforms": ["ios", "android", "web"],
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "experiments": {
      "typedRoutes": true
    },
    "plugins": ["expo-router", "expo-status-bar"]
  }
}
