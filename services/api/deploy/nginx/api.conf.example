# Reverse proxy for the Portal API.
# Copy to /etc/nginx/sites-available/api.yourdomain.ir and replace server_name.
# Enable: ln -s ... sites-enabled/  →  nginx -t  →  systemctl reload nginx
# Then: certbot --nginx -d api.yourdomain.ir

server {
    listen 80;
    listen [::]:80;
    server_name api.yourdomain.ir;

    # Certbot will add SSL listen directives here.

    location / {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 60s;
    }
}
