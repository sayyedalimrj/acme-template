# Backend API environment (NAMES ONLY — never commit real values).
# Copy to `.env` for local dev and set real values; in production use your secret manager.

# --- Core ---
NODE_ENV=development
PORT=8080

# Comma-separated list of allowed web origins (your three subdomains + local dev).
# e.g. https://app.example.com,https://admin.example.com,https://partner.example.com,http://localhost:8081
CORS_ORIGINS=http://localhost:8081

# Public base URL of THIS api (used to build gateway return URLs + webhook delivery URLs).
PUBLIC_API_BASE_URL=http://localhost:8080
# Public URLs of the merchant/affiliate portals (used to build referral links; non-secret).
PORTAL_MERCHANT_URL=
PORTAL_AFFILIATE_URL=

# --- Database (Postgres) ---
# The docker-compose dev DB uses: postgres://postgres:postgres@localhost:5432/portal
DATABASE_URL=postgres://postgres:postgres@localhost:5432/portal

# --- Auth / JWT / sessions ---
# Generate a long random value, e.g.  openssl rand -hex 32
JWT_SECRET=
# Access token lifetime (short-lived); refresh tokens extend the session.
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_DAYS=30

# --- Credential vault (AES-256-GCM) — REQUIRED in production ---
# 32-byte master key as hex (64 chars) or base64. e.g.  openssl rand -hex 32
# Encrypts WooCommerce keys + plugin signing secrets at rest. In dev a key is derived from
# JWT_SECRET if this is empty (NOT for production).
CREDENTIAL_ENCRYPTION_KEY=
CREDENTIAL_KEY_VERSION=1

# --- OTP ---
# Pepper used to hash OTP codes at rest (openssl rand -hex 32). NEVER store raw codes.
OTP_HASH_SECRET=
OTP_TTL_SECONDS=120
# 4 matches the app's OTP boxes. Raise it only if you also update the app's OTP UI length.
OTP_LENGTH=4
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_REQUESTS_PER_HOUR=10

# --- SMS provider: ippanel (https://ippanel.com) ---
# When SMS_DRY_RUN=true (or the keys below are empty) no SMS is sent; the code is logged
# (and returned in the API response only in non-production) so you can test the OTP flow.
SMS_DRY_RUN=true
IPPANEL_API_KEY=
IPPANEL_BASE_URL=https://api.ippanel.com/v1
IPPANEL_PATTERN_CODE=
IPPANEL_ORIGINATOR=
IPPANEL_OTP_VARIABLE=code
# How to send the key: "accesskey" -> Authorization: AccessKey <key>  |  "apikey" -> apikey: <key>
IPPANEL_AUTH_SCHEME=accesskey

# --- Access control ---
# Comma-separated admin mobiles allowed into the admin portal as platform_admin (09xxxxxxxxx).
ADMIN_MOBILE_ALLOWLIST=
# Comma-separated mobiles allowed as read-only support_admin.
SUPPORT_MOBILE_ALLOWLIST=
# Allow self-serve marketer signup on the affiliate portal (true/false).
AFFILIATE_OPEN_SIGNUP=true

# --- WooCommerce server-side client ---
WOO_HTTP_TIMEOUT_MS=10000
WOO_MAX_RETRIES=2

# --- WordPress plugin signed sync ---
PLUGIN_TIMESTAMP_SKEW_SECONDS=300
PLUGIN_HANDSHAKE_TTL_SECONDS=900

# --- Caching (read-heavy summary endpoints) ---
CACHE_TTL_SECONDS=30

# --- Platform subscription billing ---
# manual = admin confirms payment; mock = dev-only auto-settle; zarinpal = real gateway.
BILLING_PROVIDER=manual
ZARINPAL_MERCHANT_ID=
ZARINPAL_BASE_URL=https://payment.zarinpal.com
ZARINPAL_SANDBOX=false
# Shared secret to verify inbound payment webhooks (HMAC-SHA256 over the raw body).
PAYMENT_WEBHOOK_SECRET=
